<?xml version="1.0" encoding="utf-8"?>
<!--
  仅放行「本机回环地址」的明文 HTTP。
  本地媒体服务 (src-tauri/src/media_server.rs) 监听 127.0.0.1:<随机端口>，
  <video> 通过 http://127.0.0.1:<port>/m/<id> 取流（带 Range）。release 构建里
  usesCleartextTraffic=false 会把这条回环明文请求一并拦掉，表现为「视频无法播放」。
  这里按域单独放行 127.0.0.1 / localhost，其余域仍走系统安全默认（不允许明文）。
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="true">tauri.localhost</domain>
    </domain-config>
</network-security-config>
